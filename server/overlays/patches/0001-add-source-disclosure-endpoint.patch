diff --git a/synapse/rest/mdchat_source.py b/synapse/rest/mdchat_source.py
new file mode 100644
index 0000000..3333333
--- /dev/null
+++ b/synapse/rest/mdchat_source.py
@@ -0,0 +1,56 @@
+# SPDX-License-Identifier: AGPL-3.0-only
+# SPDX-FileCopyrightText: 2026 Mega Promoting SRL
+#
+# MD-Chat fork: AGPL §13 source-disclosure endpoint.
+#
+# Serves `/_synapse/mdchat/source` with a 302 redirect to the public fork
+# repository. The URL is taken from the MD_CHAT_SOURCE_URL environment
+# variable so mirrors and staging clones can override at deploy time.
+#
+# This route is intentionally unauthenticated — AGPL §13 applies to *every*
+# network user, anonymous included.
+
+import logging
+import os
+from typing import TYPE_CHECKING
+
+from synapse.http.server import DirectServeJsonResource
+from synapse.http.site import SynapseRequest
+from twisted.web.server import NOT_DONE_YET
+
+if TYPE_CHECKING:
+    from synapse.server import HomeServer
+
+logger = logging.getLogger(__name__)
+
+DEFAULT_SOURCE_URL = "https://github.com/megapromoting/md-chat-server"
+
+
+class MdChatSourceDisclosureResource(DirectServeJsonResource):
+    """Tiny resource that 302-redirects to the AGPL source-disclosure URL."""
+
+    isLeaf = True
+
+    def __init__(self, hs: "HomeServer") -> None:
+        super().__init__()
+        self._url = os.environ.get("MD_CHAT_SOURCE_URL", DEFAULT_SOURCE_URL)
+
+    async def _async_render_GET(self, request: SynapseRequest) -> None:
+        request.setResponseCode(302)
+        request.setHeader(b"Location", self._url.encode("utf-8"))
+        request.setHeader(b"Cache-Control", b"public, max-age=86400")
+        request.setHeader(b"X-AGPL-Notice",
+                          b"Source available per AGPLv3 section 13.")
+        request.setHeader(b"Content-Type", b"text/plain; charset=utf-8")
+        body = (
+            f"MD-Chat Server — source code (AGPLv3): {self._url}\n"
+        ).encode("utf-8")
+        request.write(body)
+        request.finish()
+        return NOT_DONE_YET  # type: ignore[return-value]
+
+
+def register_servlets(hs: "HomeServer", http_server) -> None:
+    resource = MdChatSourceDisclosureResource(hs)
+    http_server.putChild(b"_synapse", resource)
+    logger.info("MD-Chat: registered AGPL §13 source-disclosure endpoint")
