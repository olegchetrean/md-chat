{#
   password-reset.html.j2 — MD-Chat password reset email.

   Replaces synapse/res/templates/password_reset.html. Rendered by
   synapse/handlers/identity.py::send_password_reset_mail. Receives:
     - link              the validation URL (one-time token)
     - sid               session ID
     - server_name       msg.md-chat.eu
     - token_lifetime    e.g., "1h"

   Security UX rules embedded in this template:
     1. Token expiry stated explicitly (Art. 25 GDPR — privacy by default).
     2. "Didn't request this?" path included, with security@ contact.
     3. Visible footer reminder that staff never ask for passwords by email.
#}
{% extends "_base.html" %}

{% block title %}MD-Chat — Resetare parolă{% endblock %}

{% block header %}
  <a href="https://md-chat.eu" style="text-decoration:none;color:inherit">
    <img src="https://md-chat.eu/static/email/mdchat-logo.svg"
         alt="MD-Chat"
         width="180"
         style="display:block;margin:0 auto 24px;max-width:180px;height:auto">
  </a>
{% endblock %}

{% block body %}
  <h1 style="font-family:-apple-system,'Segoe UI',sans-serif;font-size:22px;color:#1a1a1a;margin:0 0 16px;text-align:center">
    Resetare parolă
  </h1>

  <p style="font-family:-apple-system,'Segoe UI',sans-serif;font-size:15px;line-height:1.55;color:#333;margin:0 0 16px">
    Cineva — sperăm că tu — a cerut resetarea parolei pentru contul tău
    MD-Chat pe homeserver-ul <code>{{ server_name }}</code>.
  </p>

  <p style="font-family:-apple-system,'Segoe UI',sans-serif;font-size:15px;line-height:1.55;color:#333;margin:0 0 24px">
    Pentru a continua, apasă butonul de mai jos. Link-ul este valabil
    <strong>{{ token_lifetime|default("o oră", true) }}</strong> și poate fi
    folosit o singură dată.
  </p>

  <p style="text-align:center;margin:32px 0">
    <a href="{{ link }}"
       style="display:inline-block;padding:14px 28px;background:#d62b2b;color:#ffffff;text-decoration:none;border-radius:6px;font-family:-apple-system,'Segoe UI',sans-serif;font-size:15px;font-weight:600">
      Resetează parola
    </a>
  </p>

  <p style="font-family:-apple-system,'Segoe UI',sans-serif;font-size:13px;line-height:1.55;color:#555;margin:0 0 16px">
    Dacă butonul nu funcționează, copiază link-ul direct în browser:
  </p>
  <p style="font-family:'SFMono-Regular',Menlo,Consolas,monospace;font-size:12px;color:#444;background:#f5f7fa;border:1px solid #e1e4e8;border-radius:4px;padding:12px;word-break:break-all;margin:0 0 24px">
    {{ link }}
  </p>

  <hr style="border:none;border-top:1px solid #e1e4e8;margin:32px 0">

  <h2 style="font-family:-apple-system,'Segoe UI',sans-serif;font-size:16px;color:#1a1a1a;margin:0 0 8px">
    Nu ai cerut tu resetarea?
  </h2>
  <p style="font-family:-apple-system,'Segoe UI',sans-serif;font-size:14px;line-height:1.55;color:#333;margin:0 0 12px">
    Ignoră acest email — parola ta rămâne neschimbată și contul este în
    siguranță. Dacă observi activitate suspectă, scrie imediat la
    <a href="mailto:security@md-chat.eu" style="color:#1f6feb">security@md-chat.eu</a>.
  </p>
{% endblock %}

{% block footer %}
  <p style="font-family:-apple-system,'Segoe UI',sans-serif;font-size:12px;color:#777;text-align:center;margin:24px 0 8px">
    <strong>Atenție:</strong> echipa MD-Chat nu îți va cere niciodată parola
    sau codul de verificare prin email, telefon sau chat.
  </p>
  <p style="font-family:-apple-system,'Segoe UI',sans-serif;font-size:11px;color:#999;text-align:center;margin:0 0 4px">
    MD-Chat este operat de <strong>Mega Promoting SRL</strong>, Chișinău, Moldova.
    Contact: <a href="mailto:support@md-chat.eu" style="color:#999">support@md-chat.eu</a>.
  </p>
  <p style="font-family:-apple-system,'Segoe UI',sans-serif;font-size:11px;color:#999;text-align:center;margin:0">
    Cod sursă disponibil sub AGPLv3 la
    <a href="https://md-chat.eu/source" style="color:#999">md-chat.eu/source</a>.
  </p>
{% endblock %}
