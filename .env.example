# MD-Chat Environment Variables — Example file
# Copy to `.env.local` and fill in REAL values. NEVER commit `.env.local` to git.

# ===========================================================================
# SERVER (Synapse fork)
# ===========================================================================
SYNAPSE_SERVER_NAME=msg.md-chat.eu
SYNAPSE_REPORT_STATS=no
SYNAPSE_LOG_LEVEL=info

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mdchat_synapse
POSTGRES_PASSWORD=__CHANGEME__
POSTGRES_DB=mdchat_synapse

REDIS_HOST=redis
REDIS_PORT=6379

# ===========================================================================
# AI LAYER (Cronberry fork)
# ===========================================================================
AI_LAYER_PORT=5002

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=__CHANGEME__

# Router by MP (Mega's AI gateway — same shop, internal pricing)
# Get a key from your Router by MP dashboard.
ROUTER_API_BASE=https://api.megapromoting.com/v1
ROUTER_API_KEY=sk-router-__CHANGEME__

# ===========================================================================
# AUTH — Infobip (SMS) — uses NEW application in Mega's Infobip account
# Create the application in portal.infobip.com → Applications → Create
# Sender ID: register `MDChat` separately, 3-5 day approval.
# ===========================================================================
INFOBIP_BASE_URL=https://api.infobip.com
INFOBIP_API_KEY=__CHANGEME__
INFOBIP_SENDER_ID=MDChat

# ===========================================================================
# AUTH — TOTP
# ===========================================================================
TOTP_ISSUER=MD-Chat
TOTP_DIGITS=6
TOTP_PERIOD=30

# ===========================================================================
# AUTH — EVO / MPass / MSign (Moldova)
# Get these from STISC after WE BUILD relying-party slot approved.
# ===========================================================================
MPASS_SP_CERT_PATH=/etc/md-chat/mpass-sp-cert.pem
MPASS_SP_KEY_PATH=/etc/md-chat/mpass-sp-key.pem
MPASS_IDP_METADATA_URL=https://mpass.gov.md/Metadata
MPASS_SP_ENTITY_ID=https://msg.md-chat.eu/saml/sp
MSIGN_API_BASE=https://msign.gov.md/services
MSIGN_API_KEY=__CHANGEME__

# ===========================================================================
# STORAGE
# ===========================================================================
MEDIA_STORE_PATH=/var/lib/mdchat/media
MEDIA_RETENTION_DAYS=365

# ===========================================================================
# EU eEvidence Regulation portal (mandatory 18 Aug 2026)
# ===========================================================================
EU_REPRESENTATIVE_NAME=Prighter SARL
EU_REPRESENTATIVE_EMAIL=legal@md-chat.eu
EU_REPRESENTATIVE_PHONE=__CHANGEME__
EEVIDENCE_PORTAL_ENABLED=true

# ===========================================================================
# AI Act Art 50 — required from 2 Aug 2026
# ===========================================================================
AI_DISCLOSURE_TEXT_RO=Sunteti in legatura cu un agent AI MD-Chat. Apel inregistrat.
AI_DISCLOSURE_TEXT_RU=Vy obshchaetes s AI-agentom MD-Chat. Razgovor zapisyvaetsya.
AI_DISCLOSURE_TEXT_EN=You are interacting with an MD-Chat AI agent. Call recorded.

# ===========================================================================
# MONITORING
# ===========================================================================
SENTRY_DSN=
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ===========================================================================
# RATE LIMITS
# ===========================================================================
SMS_COOLDOWN_SECONDS=60
SMS_MAX_PER_HOUR=5
SMS_MAX_PER_DAY=100
SIGNUP_MAX_PER_HOUR_PER_IP=20

# ===========================================================================
# DEV / DEBUG
# ===========================================================================
NODE_ENV=development
DEBUG=mdchat:*
