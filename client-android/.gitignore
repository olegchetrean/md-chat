# MD-Chat Android — overlay-only directory
# Most of this is defensive: this directory ships no Gradle build,
# but we want clean status after running scripts/fork-bootstrap.sh
# in a sibling working tree.

# Android Studio / IntelliJ
.idea/
*.iml
*.iws
*.ipr
.run/
out/

# Gradle
.gradle/
build/
**/build/
gradle-app.setting
!gradle-wrapper.jar
!gradle-wrapper.properties
.gradletasknamecache
local.properties

# Kotlin
.kotlin/
*.kotlin_metadata
*.kotlin_module
hs_err_pid*

# Android build artefacts
*.apk
*.aab
*.aar
*.ap_
*.dex
*.class
output.json
release/
debug/
captures/

# Native
.cxx/
*.so
*.so.dbg

# Keystores — NEVER commit
*.jks
*.keystore
*.p12
*.pem
*.pfx
keystore.properties
keystore.properties.local
play-service-account.json
firebase-app-distribution.json

# Local config
google-services.json
fdroid-private/
*.env
.env
.env.local
.env.*.local

# macOS / Linux / Windows
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Logs
*.log
logs/
hs_err_pid*.log

# CI temp / scratch
/tmp/
.tmp/
.cache/
*.tmp
*.swp
*.swo

# Sentry / PostHog source maps
.sentryclirc
sourcemaps/

# F-Droid local repo
fdroid/repo/
fdroid/tmp/
fdroid/unsigned/
fdroid/srclibs/
fdroid/metadata/*.yml.disabled

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/

# Bootstrap working trees (sibling clones of upstream)
/upstream-clone/
/work/

# Generated by apply-branding.sh
overlays/.applied.lock
overlays/.last-substitution-hash
