version: 1

formatters:
  precise:
    format: '%(asctime)s - %(name)s - %(lineno)d - %(levelname)s - %(request)s - %(message)s'

handlers:
  console:
    class: logging.StreamHandler
    formatter: precise
    level: INFO

loggers:
  synapse.storage.SQL:
    level: WARNING
  synapse.access.http.8008:
    level: INFO

root:
  level: INFO
  handlers: [console]

disable_existing_loggers: false
