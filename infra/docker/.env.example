# Docker compose environment variables for MD-Chat deployment.
# Copy to `.env` and fill in real values. NEVER commit `.env` to git.

POSTGRES_PASSWORD=__CHANGEME_strong_random_password__
REDIS_PASSWORD=__CHANGEME_strong_random_password__
NEO4J_PASSWORD=__CHANGEME_strong_random_password__

SYNAPSE_SERVER_NAME=msg.md-chat.eu

# Router by MP — internal AI gateway
ROUTER_API_BASE=https://api.megapromoting.com/v1
ROUTER_API_KEY=__GET_FROM_ROUTER_DASHBOARD__

# Infobip — SMS OTP for signup MFA (new application in Mega's account)
INFOBIP_BASE_URL=https://api.infobip.com
INFOBIP_API_KEY=__FROM_INFOBIP_PORTAL_NEW_APPLICATION__
INFOBIP_SENDER_ID=MDChat

# Optional Sentry self-hosted
SENTRY_DSN=
