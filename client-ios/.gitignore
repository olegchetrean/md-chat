# =============================================================
# md-chat-ios .gitignore
# =============================================================
# This shell tracks only overlay files. The full Element X iOS
# checkout lives in `upstream/` and must never be committed.
# =============================================================

# ---- Upstream fork (cloned by fork-bootstrap.sh) ------------
upstream/
.upstream-tag

# ---- Xcode user data ---------------------------------------
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcworkspace/xcuserdata/
xcuserdata/
*.xcuserstate
*.xcuserdatad/

# ---- Xcode generated -----------------------------------------
# Project files are regenerated by XcodeGen — never commit.
*.xcodeproj/project.pbxproj
*.xcodeproj/xcshareddata/IDEWorkspaceChecks.plist

# ---- Swift Package Manager ----------------------------------
.swiftpm/
.build/
Packages/
Package.pins
Package.resolved
*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/

# ---- DerivedData --------------------------------------------
DerivedData/
build/
*.dSYM.zip
*.dSYM

# ---- CocoaPods ----------------------------------------------
# (Element X uses SPM, not CocoaPods, but guard anyway.)
Pods/
Podfile.lock

# ---- Carthage -----------------------------------------------
Carthage/Build/
Carthage/Checkouts/

# ---- Mint (tool versioning) --------------------------------
.mint/

# ---- Fastlane -----------------------------------------------
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/
fastlane/README.md
*.mobileprovision
*.cer
*.p12
*.p8

# ---- Generated by SwiftGen / Sourcery / Mockingbird ----
**/Generated/Strings.swift
**/Generated/Asset.swift
**/Generated/AutoMockable.generated.swift

# ---- Localazy (Element upstream uses it; we don't) --------
.localazy/

# ---- macOS noise --------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# ---- IDE editors --------------------------------------------
.idea/
.vscode/
*.swp
*.swo

# ---- Secrets — NEVER commit ---------------------------------
*.env
*.env.local
.env.local
secrets/
fastlane/AuthKey_*.p8
fastlane/Appfile.local

# ---- Local-only output --------------------------------------
*.ipa
*.app.zip
artifacts/
out/
